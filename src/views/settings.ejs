<% const activeSection = typeof section === 'string' ? section : 'overview'; const currentCriteria = criteria.find((item) => item.status === 'active'); const draftCriteria = criteria.find((item) => item.status === 'draft'); const copy = locale === 'ru' ? {
  subtitle: 'Управление поиском, критериями и автоматизацией', overview: 'Обзор', automation: 'Автоматизация', criteria: 'Критерии', expert: 'Для специалистов', activeVersion: 'Рабочая версия', activeHelp: 'Эти правила сейчас использует обработчик.', draftVersion: 'Черновик изменений', noDraft: 'Нет неактивированных изменений', daily: 'Автопоиск сегодня', pending: 'Ожидают пересчёта', open: 'Открыть', proposal: 'Предложить улучшения с ИИ', versions: 'История версий', source: 'Источник', activate: 'Сделать рабочей', rejectDraft: 'Отклонить черновик', compare: 'Сравнить с рабочей версией',
  automationTitle: 'Автоматизация поиска', automationHelp: 'Сохранение создаст черновик. Изменения начнут работать только после активации на вкладке «Обзор».', criteriaEnabled: 'ИИ предлагает обновления критериев', criteriaEnabledHelp: 'ИИ создаёт только черновик и никогда не активирует его сам.', decisions: 'Решений до пересчёта', hours: 'Максимальный интервал, часов', discoveryEnabled: 'Автоматически искать кандидатов', discoveryHelp: 'Используются запросы только из рабочей версии критериев.', dailyLimit: 'Дневной лимит аккаунтов', queryLimit: 'Лимит на один запрос', saveDraft: 'Сохранить как черновик',
  criteriaTitle: 'Правила отбора', criteriaHelp: 'Опишите понятным языком, кого считать подходящим блогером. По одному поисковому запросу на строку.', checklist: 'Критерии и ограничения', queries: 'Поисковые запросы',
  expertTitle: 'Экспертные настройки', expertHelp: 'Технические поля влияют на работу ИИ. Изменяйте их только если понимаете последствия.', prompts: 'Промпты LLM', analysis: 'Анализ блогера', outreach: 'Написание оффера', promptsHelp: 'Профиль, критерии и расшифровки добавляются к этим инструкциям автоматически.', raw: 'Полная техническая конфигурация', rawHelp: 'JSON правил расшифровки и внутренних параметров.', logs: 'Журнал запросов к ИИ', request: 'Запрос', parsed: 'Результат', rawResponse: 'Исходный ответ', noLogs: 'Запросов пока не было'
} : {
  subtitle: 'Manage search, criteria, and automation', overview: 'Overview', automation: 'Automation', criteria: 'Criteria', expert: 'For specialists', activeVersion: 'Live version', activeHelp: 'These rules are currently used by the worker.', draftVersion: 'Changes draft', noDraft: 'No changes waiting for activation', daily: 'Automatic search today', pending: 'Waiting for recalculation', open: 'Open', proposal: 'Suggest improvements with AI', versions: 'Version history', source: 'Source', activate: 'Make live', rejectDraft: 'Reject draft', compare: 'Compare with live version',
  automationTitle: 'Search automation', automationHelp: 'Saving creates a draft. Changes only take effect after activation on the Overview tab.', criteriaEnabled: 'AI suggests criteria updates', criteriaEnabledHelp: 'AI only creates drafts and never activates them.', decisions: 'Decisions before recalculation', hours: 'Maximum interval, hours', discoveryEnabled: 'Automatically find candidates', discoveryHelp: 'Only queries from the live criteria version are used.', dailyLimit: 'Daily account limit', queryLimit: 'Limit per query', saveDraft: 'Save as draft',
  criteriaTitle: 'Selection rules', criteriaHelp: 'Describe suitable creators in plain language. Enter one search query per line.', checklist: 'Criteria and restrictions', queries: 'Search queries',
  expertTitle: 'Expert settings', expertHelp: 'Technical fields affect AI behavior. Change them only if you understand the impact.', prompts: 'LLM prompts', analysis: 'Creator analysis', outreach: 'Proposal writing', promptsHelp: 'Profile, criteria, and transcripts are appended to these instructions automatically.', raw: 'Full technical configuration', rawHelp: 'Transcript rules and internal parameters as JSON.', logs: 'AI request log', request: 'Request', parsed: 'Result', rawResponse: 'Raw response', noLogs: 'No requests yet'
}; %>
<%- include('partials/head', { title }) %><%- include('partials/nav', { active }) %>
<main class="page settings-page"><div class="page-heading"><div><span class="eyebrow"><%= t('system') %> · <%= title %></span><h1><%= title %></h1><p class="muted"><%= copy.subtitle %></p></div><form method="post" action="/criteria/proposals"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><button class="button secondary"><%= copy.proposal %></button></form></div>
<nav class="section-tabs" aria-label="<%= title %>"><a class="<%= activeSection === 'overview' ? 'active' : '' %>" href="/settings?section=overview"><%= copy.overview %></a><a class="<%= activeSection === 'automation' ? 'active' : '' %>" href="/settings?section=automation"><%= copy.automation %></a><a class="<%= activeSection === 'criteria' ? 'active' : '' %>" href="/settings?section=criteria"><%= copy.criteria %></a><a class="<%= activeSection === 'expert' ? 'active' : '' %>" href="/settings?section=expert"><%= copy.expert %></a></nav>

<% if (activeSection === 'overview') { %>
  <section class="summary-grid settings-summary"><div class="summary-card"><span><%= copy.activeVersion %></span><strong><%= currentCriteria ? `v${currentCriteria.version_number}` : '—' %></strong><small><%= copy.activeHelp %></small></div><div class="summary-card <%= draftCriteria ? 'summary-warning' : '' %>"><span><%= copy.draftVersion %></span><strong><%= draftCriteria ? `v${draftCriteria.version_number}` : '—' %></strong><small><%= draftCriteria ? (draftCriteria.diff_summary || copy.draftVersion) : copy.noDraft %></small></div><a class="summary-card" href="/settings?section=automation"><span><%= copy.daily %></span><strong><%= automationStatus.discovery_used_today %> / <%= criteriaAutomation.dailyDiscoveryLimit %></strong><small><%= copy.pending %>: <%= automationStatus.pending_criteria_jobs %></small></a></section>
  <section class="panel version-panel"><div class="section-heading"><div><h2><%= copy.versions %></h2><p class="muted"><%= copy.activeHelp %></p></div></div><div class="version-list"><% criteria.forEach((item) => { const sourceLabel = item.source === 'manual' ? (locale === 'ru' ? 'вручную' : 'manual') : item.source === 'seed' ? (locale === 'ru' ? 'начальная настройка' : 'initial setup') : 'AI'; const diffLabel = item.diff_summary === 'Initial criteria imported from legacy documents' ? (locale === 'ru' ? 'Начальные критерии проекта' : 'Initial project criteria') : item.diff_summary; %><article class="version-item"><div class="version-number">v<%= item.version_number %></div><div class="version-content"><div><span class="chip status-<%= item.status %>"><%= t(`status.${item.status}`) %></span><span class="muted"><%= copy.source %>: <%= sourceLabel %></span></div><strong><%= diffLabel || '—' %></strong><small><time data-utc="<%= item.created_at.toISOString() %>"></time></small><% if (item.status === 'draft' && currentCriteria) { %><details class="compare-details"><summary><%= copy.compare %></summary><div class="compare"><pre><%= currentCriteria.checklist_markdown %></pre><pre><%= item.checklist_markdown %></pre></div></details><% } %></div><div class="row-actions"><% if (item.status === 'draft') { %><form method="post" action="/criteria/<%= item.id %>/activate" data-confirm="<%= copy.activate %> v<%= item.version_number %>?"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><button class="button success"><%= copy.activate %></button></form><form method="post" action="/criteria/<%= item.id %>/reject"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><button class="button tertiary danger-text"><%= copy.rejectDraft %></button></form><% } %></div></article><% }) %></div></section>
<% } %>

<% if (activeSection === 'automation') { %><section class="panel form-panel"><div class="section-heading"><div><h2><%= copy.automationTitle %></h2><p class="muted"><%= copy.automationHelp %></p></div><div class="usage-badge"><%= copy.daily %>: <strong><%= automationStatus.discovery_used_today %> / <%= criteriaAutomation.dailyDiscoveryLimit %></strong></div></div><form method="post" action="/automation/drafts" class="settings-form"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><label class="toggle-row"><input type="checkbox" name="criteriaEnabled" <%= criteriaAutomation.criteriaEnabled ? 'checked' : '' %>><span><strong><%= copy.criteriaEnabled %></strong><small><%= copy.criteriaEnabledHelp %></small></span></label><div class="form-grid"><label><span><%= copy.decisions %></span><input type="number" name="decisionThreshold" min="1" max="100" value="<%= criteriaAutomation.decisionThreshold %>" required></label><label><span><%= copy.hours %></span><input type="number" name="refreshHours" min="1" max="168" value="<%= criteriaAutomation.refreshHours %>" required></label></div><hr><label class="toggle-row"><input type="checkbox" name="discoveryEnabled" <%= criteriaAutomation.discoveryEnabled ? 'checked' : '' %>><span><strong><%= copy.discoveryEnabled %></strong><small><%= copy.discoveryHelp %></small></span></label><div class="form-grid"><label><span><%= copy.dailyLimit %></span><input type="number" name="dailyDiscoveryLimit" min="1" max="100" value="<%= criteriaAutomation.dailyDiscoveryLimit %>" required></label><label><span><%= copy.queryLimit %></span><input type="number" name="perQueryLimit" min="1" max="100" value="<%= criteriaAutomation.perQueryLimit %>" required></label></div><div class="form-actions"><button class="button primary"><%= copy.saveDraft %></button></div></form></section><% } %>

<% if (activeSection === 'criteria') { %><section class="panel form-panel"><div class="section-heading"><div><h2><%= copy.criteriaTitle %></h2><p class="muted"><%= copy.criteriaHelp %></p></div></div><form class="settings-form" method="post" action="/criteria/drafts"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><label><span><%= copy.checklist %></span><textarea name="checklistMarkdown" rows="18" required><%= currentCriteria?.checklist_markdown || '' %></textarea></label><label><span><%= copy.queries %></span><textarea name="searchQueries" rows="7"><%= (currentCriteria?.search_queries || []).join('\n') %></textarea></label><textarea name="transcriptRules" hidden><%= JSON.stringify(currentCriteria?.transcript_rules || {}) %></textarea><div class="form-actions"><button class="button primary"><%= copy.saveDraft %></button></div></form></section><% } %>

<% if (activeSection === 'expert') { %><div class="expert-warning"><strong><%= copy.expertTitle %></strong><span><%= copy.expertHelp %></span></div><section class="panel form-panel"><div class="section-heading"><div><h2><%= copy.prompts %></h2><p class="muted"><%= copy.promptsHelp %></p></div></div><form method="post" action="/prompts/drafts" class="settings-form"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><label><span><%= copy.analysis %></span><textarea name="candidateEvaluation" rows="12" maxlength="12000" required><%= llmPrompts.candidateEvaluation %></textarea></label><label><span><%= copy.outreach %></span><textarea name="outreachProposal" rows="12" maxlength="12000" required><%= llmPrompts.outreachProposal %></textarea></label><div class="form-actions"><button class="button primary"><%= copy.saveDraft %></button></div></form></section><section class="panel form-panel"><details><summary class="details-heading"><strong><%= copy.raw %></strong><small><%= copy.rawHelp %></small></summary><form class="settings-form inset-form" method="post" action="/criteria/drafts"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><label><span><%= copy.checklist %></span><textarea name="checklistMarkdown" rows="10" required><%= currentCriteria?.checklist_markdown || '' %></textarea></label><label><span><%= copy.queries %></span><textarea name="searchQueries" rows="5"><%= (currentCriteria?.search_queries || []).join('\n') %></textarea></label><label><span>Transcript rules JSON</span><textarea name="transcriptRules" rows="14"><%= JSON.stringify(currentCriteria?.transcript_rules || {}, null, 2) %></textarea></label><button class="button primary"><%= copy.saveDraft %></button></form></details></section><section class="panel log-panel"><div class="section-heading"><div><h2><%= copy.logs %></h2></div></div><% if (!llmLogs.length) { %><p class="muted"><%= copy.noLogs %></p><% } %><% llmLogs.forEach((log) => { %><details class="log-item"><summary><div><strong><%= log.purpose %></strong><small><%= log.model %> · <time data-utc="<%= log.created_at.toISOString() %>"></time></small></div><span class="chip status-<%= log.status %>"><%= t(`status.${log.status}`) %></span></summary><h3><%= copy.request %></h3><pre><%= JSON.stringify(log.request_messages, null, 2) %></pre><h3><%= copy.parsed %></h3><pre><%= JSON.stringify(log.parsed_response, null, 2) %></pre><h3><%= copy.rawResponse %></h3><pre><%= JSON.stringify(log.raw_response, null, 2) %></pre><% if (log.error_detail) { %><p class="error-text"><%= log.error_detail %></p><% } %></details><% }) %></section><% } %>
</main><%- include('partials/foot') %>

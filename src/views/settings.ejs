<%- include('partials/head', { title }) %><%- include('partials/nav', { active }) %>
<main class="page"><div class="page-heading"><div><h1><%= title %></h1><p class="muted">Criteria versions and LLM proposals</p></div><form method="post" action="/criteria/proposals"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><button class="button primary">Ask LLM for proposal</button></form></div>
<section class="settings-grid"><form class="panel stack" method="post" action="/criteria/drafts"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><h2>New manual draft</h2><label>Checklist Markdown<textarea name="checklistMarkdown" rows="14" required><%= criteria.find((c) => c.status === 'active')?.checklist_markdown || '' %></textarea></label><label>Search queries, one per line<textarea name="searchQueries" rows="6"><%= (criteria.find((c) => c.status === 'active')?.search_queries || []).join('\n') %></textarea></label><label>Transcript rules JSON<textarea name="transcriptRules" rows="10"><%= JSON.stringify(criteria.find((c) => c.status === 'active')?.transcript_rules || {}, null, 2) %></textarea></label><button class="button primary">Save draft</button></form>
<section class="panel"><h2>Version history</h2><% const activeCriteria = criteria.find((c) => c.status === 'active'); criteria.forEach((item) => { %><article class="version-row"><div><strong>v<%= item.version_number %></strong> <span class="chip"><%= item.status %></span><small class="block"><%= item.source %> · <time data-utc="<%= item.created_at.toISOString() %>"></time></small><p><%= item.diff_summary || '' %></p><% if (item.status === 'draft' && activeCriteria) { %><details><summary>Compare with active</summary><div class="compare"><pre><%= activeCriteria.checklist_markdown %></pre><pre><%= item.checklist_markdown %></pre></div></details><% } %></div><div class="row-actions"><% if (item.status === 'draft') { %><form method="post" action="/criteria/<%= item.id %>/activate" data-confirm="Activate criteria v<%= item.version_number %>?"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><button class="button success">Activate</button></form><form method="post" action="/criteria/<%= item.id %>/reject"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><button class="button danger">Reject</button></form><% } %></div></article><% }) %></section></section>
<section class="panel"><h2>LLM logs</h2><% if (!llmLogs.length) { %><p class="muted"><%= t('noData') %></p><% } %><% llmLogs.forEach((log) => { %><details class="version-row"><summary><strong><%= log.purpose %></strong> <span class="chip"><%= log.status %></span> · <%= log.model %> · <time data-utc="<%= log.created_at.toISOString() %>"></time></summary><h3>Request</h3><pre><%= JSON.stringify(log.request_messages, null, 2) %></pre><h3>Parsed response</h3><pre><%= JSON.stringify(log.parsed_response, null, 2) %></pre><h3>Raw response</h3><pre><%= JSON.stringify(log.raw_response, null, 2) %></pre><% if (log.error_detail) { %><p class="error-text"><%= log.error_detail %></p><% } %></details><% }) %></section>
</main><%- include('partials/foot') %>

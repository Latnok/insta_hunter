<%- include('partials/head', { title }) %><%- include('partials/nav', { active }) %>
<main class="page"><div class="page-heading"><div><h1><%= title %></h1><p class="muted">Criteria versions and LLM proposals</p></div><form method="post" action="/criteria/proposals"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><button class="button primary">Ask LLM for proposal</button></form></div>
<section class="panel stack prompt-editor">
  <div><h2>Промпты LLM</h2><p class="muted">Показаны промпты активной версии<% const currentCriteria = criteria.find((item) => item.status === 'active'); if (currentCriteria) { %> v<%= currentCriteria.version_number %><% } %>. Они используются при анализе кандидата и подготовке бартерного оффера. Сохранение создаёт новую draft-версию критериев; чтобы worker начал её использовать, нажмите Activate в истории версий.</p></div>
  <form method="post" action="/prompts/drafts" class="stack">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    <label><strong>Анализ блогера</strong><small class="muted">Профиль, критерии и расшифровки добавляются к этому системному промпту автоматически.</small><textarea name="candidateEvaluation" rows="10" maxlength="12000" required><%= llmPrompts.candidateEvaluation %></textarea></label>
    <label><strong>Написание оффера</strong><small class="muted">Профиль, оценка и последние рилсы добавляются автоматически. Текст должен оставаться основанным на фактах.</small><textarea name="outreachProposal" rows="12" maxlength="12000" required><%= llmPrompts.outreachProposal %></textarea></label>
    <button class="button primary">Сохранить как draft</button>
  </form>
</section>
<section class="panel stack automation-editor">
  <div><h2>Автоматизация поиска</h2><p class="muted">Показаны настройки активной версии. Сохранение создаёт draft: автоматика изменится только после Activate. Ручные задания всегда имеют более высокий приоритет.</p><p class="muted">Сегодня поставлено в поиск: <strong><%= automationStatus.discovery_used_today %> из <%= criteriaAutomation.dailyDiscoveryLimit %></strong>. Ожидает LLM-пересчёта: <strong><%= automationStatus.pending_criteria_jobs %></strong>.<% if (automationStatus.last_discovery_at) { %> Последний автопоиск: <time data-utc="<%= automationStatus.last_discovery_at.toISOString() %>"></time>.<% } %></p></div>
  <form method="post" action="/automation/drafts" class="stack">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    <label class="check"><input type="checkbox" name="criteriaEnabled" <%= criteriaAutomation.criteriaEnabled ? 'checked' : '' %>> <span><strong>LLM обновляет критерии</strong><small class="muted block">Создаёт только draft, никогда не активирует его самостоятельно.</small></span></label>
    <div class="automation-grid">
      <label>Новых решений до пересчёта<input type="number" name="decisionThreshold" min="1" max="100" value="<%= criteriaAutomation.decisionThreshold %>" required></label>
      <label>Максимальный интервал, часов<input type="number" name="refreshHours" min="1" max="168" value="<%= criteriaAutomation.refreshHours %>" required></label>
    </div>
    <label class="check"><input type="checkbox" name="discoveryEnabled" <%= criteriaAutomation.discoveryEnabled ? 'checked' : '' %>> <span><strong>Автоматически искать кандидатов</strong><small class="muted block">Использует только запросы активной версии критериев.</small></span></label>
    <div class="automation-grid">
      <label>Дневной лимит аккаунтов<input type="number" name="dailyDiscoveryLimit" min="1" max="100" value="<%= criteriaAutomation.dailyDiscoveryLimit %>" required></label>
      <label>Лимит на один запрос<input type="number" name="perQueryLimit" min="1" max="100" value="<%= criteriaAutomation.perQueryLimit %>" required></label>
    </div>
    <button class="button primary">Сохранить настройки как draft</button>
  </form>
</section>
<section class="settings-grid"><form class="panel stack" method="post" action="/criteria/drafts"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><h2>New manual draft</h2><label>Checklist Markdown<textarea name="checklistMarkdown" rows="14" required><%= criteria.find((c) => c.status === 'active')?.checklist_markdown || '' %></textarea></label><label>Search queries, one per line<textarea name="searchQueries" rows="6"><%= (criteria.find((c) => c.status === 'active')?.search_queries || []).join('\n') %></textarea></label><label>Transcript rules JSON<textarea name="transcriptRules" rows="10"><%= JSON.stringify(criteria.find((c) => c.status === 'active')?.transcript_rules || {}, null, 2) %></textarea></label><button class="button primary">Save draft</button></form>
<section class="panel"><h2>Version history</h2><% const activeCriteria = criteria.find((c) => c.status === 'active'); criteria.forEach((item) => { const versionPrompts = item.transcript_rules?.llmPrompts; const selectionModel = item.transcript_rules?.selectionModel; %><article class="version-row"><div><strong>v<%= item.version_number %></strong> <span class="chip"><%= item.status %></span><small class="block"><%= item.source %> · <time data-utc="<%= item.created_at.toISOString() %>"></time></small><p><%= item.diff_summary || '' %></p><% if (selectionModel) { %><details class="prompt-version"><summary>Модель отбора этой версии</summary><pre><%= JSON.stringify(selectionModel, null, 2) %></pre></details><% } %><% if (versionPrompts) { %><details class="prompt-version"><summary>Промпты этой версии</summary><h3>Анализ блогера</h3><pre><%= versionPrompts.candidateEvaluation %></pre><h3>Написание оффера</h3><pre><%= versionPrompts.outreachProposal %></pre></details><% } %><% if (item.status === 'draft' && activeCriteria) { %><details><summary>Compare with active</summary><div class="compare"><pre><%= activeCriteria.checklist_markdown %></pre><pre><%= item.checklist_markdown %></pre></div></details><% } %></div><div class="row-actions"><% if (item.status === 'draft') { %><form method="post" action="/criteria/<%= item.id %>/activate" data-confirm="Activate criteria v<%= item.version_number %>?"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><button class="button success">Activate</button></form><form method="post" action="/criteria/<%= item.id %>/reject"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><button class="button danger">Reject</button></form><% } %></div></article><% }) %></section></section>
<section class="panel"><h2>LLM logs</h2><% if (!llmLogs.length) { %><p class="muted"><%= t('noData') %></p><% } %><% llmLogs.forEach((log) => { %><details class="version-row"><summary><strong><%= log.purpose %></strong> <span class="chip"><%= log.status %></span> · <%= log.model %> · <time data-utc="<%= log.created_at.toISOString() %>"></time></summary><h3>Request</h3><pre><%= JSON.stringify(log.request_messages, null, 2) %></pre><h3>Parsed response</h3><pre><%= JSON.stringify(log.parsed_response, null, 2) %></pre><h3>Raw response</h3><pre><%= JSON.stringify(log.raw_response, null, 2) %></pre><% if (log.error_detail) { %><p class="error-text"><%= log.error_detail %></p><% } %></details><% }) %></section>
</main><%- include('partials/foot') %>

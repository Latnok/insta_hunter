<% const copy = locale === 'ru' ? { subtitle: 'Материалы, на которых основаны оценки кандидатов', search: 'Автор или @username', all: 'Любое качество', emptyTitle: 'Контент не найден', emptyText: 'Измените фильтры или дождитесь завершения обработки кандидатов.', open: 'Открыть материал', instagram: 'Открыть в Instagram' } : { subtitle: 'Content used for candidate evaluations', search: 'Creator or @username', all: 'Any quality', emptyTitle: 'No content found', emptyText: 'Change the filters or wait for candidate processing to finish.', open: 'Open content', instagram: 'Open in Instagram' }; %>
<%- include('partials/head', { title }) %><%- include('partials/nav', { active }) %>
<main class="page"><div class="page-heading"><div><span class="eyebrow">03 · <%= title %></span><h1><%= title %></h1><p class="muted"><%= copy.subtitle %></p></div></div>
<form class="filters filter-bar" method="get"><label><span class="sr-only"><%= t('search') %></span><input name="search" value="<%= query.search || '' %>" placeholder="<%= copy.search %>"></label><label><span class="sr-only">Quality</span><select name="quality"><option value=""><%= copy.all %></option><% ['useful','noise','low_value','empty'].forEach((q) => { %><option value="<%= q %>" <%= query.quality === q ? 'selected' : '' %>><%= t(`quality.${q}`) %></option><% }) %></select></label><button class="button secondary"><%= t('search') %></button></form>
<% if (!reels.length) { %><section class="empty-state"><div class="empty-icon">▶</div><h2><%= copy.emptyTitle %></h2><p><%= copy.emptyText %></p></section><% } else { %><section class="card-grid content-grid"><% reels.forEach((reel) => { %><article class="card content-card"><button class="card-open reel-open" hx-get="/ui/reels/<%= reel.id %>" hx-target="#drawer" hx-swap="innerHTML" aria-label="<%= copy.open %>"><div class="thumbnail-wrap"><% if (reel.thumbnail_url) { %><img class="thumbnail" src="/media/reels/<%= reel.id %>/thumbnail" alt="" loading="lazy"><% } else { %><div class="thumbnail thumbnail-placeholder">▶</div><% } %><span class="content-open">→</span></div><div class="card-body"><strong>@<%= reel.username %></strong><p class="two-lines"><%= reel.caption || reel.transcript_text || '—' %></p><div class="chips"><span class="chip"><%= t(`status.${reel.transcript_status}`) %></span><% if (reel.transcript_quality) { %><span class="chip quality-<%= reel.transcript_quality %>"><%= t(`quality.${reel.transcript_quality}`) %></span><% } %></div><div class="metrics"><span><strong><%= reel.play_count == null ? '—' : Number(reel.play_count).toLocaleString(locale) %></strong><small><%= t('metric.plays') %></small></span><span><strong><%= reel.like_count == null ? '—' : Number(reel.like_count).toLocaleString(locale) %></strong><small><%= t('metric.likes') %></small></span></div></div></button><a class="button secondary full" href="<%= reel.reel_url %>" target="_blank" rel="noopener"><%= copy.instagram %> ↗</a></article><% }) %></section><% } %>
</main><%- include('partials/foot') %>

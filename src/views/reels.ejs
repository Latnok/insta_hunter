<%- include('partials/head', { title }) %><%- include('partials/nav', { active }) %>
<main class="page"><div class="page-heading"><h1><%= title %></h1></div>
<form class="filters" method="get"><input name="search" value="<%= query.search || '' %>" placeholder="@username"><select name="quality"><option value="">all quality</option><% ['useful','noise','low_value','empty'].forEach((q) => { %><option value="<%= q %>" <%= query.quality === q ? 'selected' : '' %>><%= q %></option><% }) %></select><button class="button secondary"><%= t('search') %></button></form>
<section class="card-grid"><% reels.forEach((reel) => { %><article class="card reel-card"><button class="card-open reel-open" hx-get="/ui/reels/<%= reel.id %>" hx-target="#drawer" hx-swap="innerHTML"><% if (reel.thumbnail_url) { %><img class="thumbnail" src="/media/reels/<%= reel.id %>/thumbnail" alt="" loading="lazy"><% } %></button><div class="card-body"><strong>@<%= reel.username %></strong><p class="two-lines"><%= reel.caption || reel.transcript_text || '—' %></p><div class="chips"><span class="chip"><%= reel.transcript_status %></span><% if (reel.transcript_quality) { %><span class="chip"><%= reel.transcript_quality %></span><% } %></div><div class="metrics"><span><strong><%= reel.play_count ?? '—' %></strong><small>plays</small></span><span><strong><%= reel.like_count ?? '—' %></strong><small>likes</small></span></div><a class="button secondary full" href="<%= reel.reel_url %>" target="_blank" rel="noopener">Instagram ↗</a></div></article><% }) %></section>
</main><%- include('partials/foot') %>

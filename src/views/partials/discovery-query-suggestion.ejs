<% const copy = locale === 'ru' ? { preparing: 'ИИ готовит запрос…', preparingHelp: 'Обычно это занимает до двух минут. Можно продолжать работать.', retrying: 'ИИ повторяет попытку', retryHelp: 'Предыдущая попытка не завершилась.', ready: 'Запрос готов', readyHelp: 'Обновляем страницу и подставляем его в поле…', empty: 'ИИ не предложил запросов. Проверьте активные критерии.', failed: 'Не удалось подготовить запрос', unknown: 'Неизвестная ошибка', again: 'Попробовать снова' } : { preparing: 'AI is preparing a query…', preparingHelp: 'This usually takes up to two minutes. You can keep working.', retrying: 'AI is retrying', retryHelp: 'The previous attempt did not finish.', ready: 'Query is ready', readyHelp: 'Refreshing the page and filling the field…', empty: 'AI did not suggest any queries. Check the active criteria.', failed: 'Could not prepare a query', unknown: 'Unknown error', again: 'Try again' }; %>
<div id="ai-query-suggestion" class="ai-helper"<% if (['pending', 'running', 'retry_wait'].includes(job.status)) { %> hx-get="/ui/discovery-query-suggestions/<%= job.id %>" hx-trigger="every 2s" hx-swap="outerHTML"<% } %>><% if (['pending', 'running'].includes(job.status)) { %><span class="chip status-running"><%= copy.preparing %></span><small class="muted"><%= copy.preparingHelp %></small><% } else if (job.status === 'retry_wait') { %><span class="chip status-retry_wait"><%= copy.retrying %></span><small class="muted"><%= job.error_summary || copy.retryHelp %></small><% } else if (job.status === 'succeeded' && queries.length) { %><span class="chip status-succeeded"><%= copy.ready %></span><small class="muted"><%= copy.readyHelp %></small><% } else if (job.status === 'succeeded') { %><p class="error-text"><%= copy.empty %></p><% } else { %><p class="error-text"><%= copy.failed %>: <%= job.error_summary || copy.unknown %></p><form hx-post="/discovery-query-suggestions" hx-target="#ai-query-suggestion" hx-swap="outerHTML"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><button class="button secondary"><%= copy.again %></button></form><% } %></div>

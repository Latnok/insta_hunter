<% const headerAutomation = typeof automationToggles !== 'undefined'
  ? automationToggles
  : { discoveryEnabled: false, processingEnabled: false }; %>
<% const headerReturnPath = typeof currentPath !== 'undefined' ? currentPath : '/candidates'; %>
<header class="topbar">
  <a class="brand" href="/candidates"><span class="brand-mark">IH</span><span>Instagram Hunter</span></a>
  <nav class="tabs" aria-label="<%= t('nav.primary') %>">
    <a class="tab <%= active === 'candidates' ? 'active' : '' %>" href="/candidates"><%= t('candidates') %></a>
    <a class="tab <%= active === 'bloggers' ? 'active' : '' %>" href="/bloggers"><%= t('bloggers') %></a>
    <a class="tab <%= active === 'content' || active === 'reels' ? 'active' : '' %>" href="/reels"><%= t('content') %></a>
  </nav>
  <div class="top-actions">
    <div class="header-automation" aria-label="<%= t('automation.controls') %>">
      <% [
        { key: 'discoveryEnabled', label: t('automation.discovery'), help: t('automation.discoveryHelp') },
        { key: 'processingEnabled', label: t('automation.processing'), help: t('automation.processingHelp') }
      ].forEach((toggle) => { const enabled = Boolean(headerAutomation[toggle.key]); %>
        <form method="post" action="/automation/toggles" class="inline-form">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <input type="hidden" name="setting" value="<%= toggle.key %>">
          <input type="hidden" name="enabled" value="<%= enabled ? 'false' : 'true' %>">
          <input type="hidden" name="returnTo" value="<%= headerReturnPath %>">
          <button class="automation-toggle <%= enabled ? 'is-on' : 'is-off' %>" role="switch" aria-checked="<%= enabled ? 'true' : 'false' %>" title="<%= toggle.help %>: <%= enabled ? t('automation.on') : t('automation.off') %>">
            <span class="automation-toggle-label"><%= toggle.label %></span>
            <span class="automation-switch" aria-hidden="true"><span></span></span>
            <span class="automation-toggle-state"><%= enabled ? t('automation.on') : t('automation.off') %></span>
          </button>
        </form>
      <% }) %>
    </div>
    <form method="post" action="/preferences/language" class="inline-form">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <input type="hidden" name="locale" value="<%= locale === 'ru' ? 'en' : 'ru' %>">
      <button class="text-button" aria-label="<%= t('nav.language') %>"><%= locale.toUpperCase() %></button>
    </form>
    <a class="system-link <%= ['queue','settings'].includes(active) ? 'active' : '' %>" href="/queue"><span aria-hidden="true">⚙</span><span><%= t('system') %></span></a>
    <form method="post" action="/auth/logout" class="inline-form">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <button class="icon-button" aria-label="<%= t('logout') %>" title="<%= t('logout') %>">↪</button>
    </form>
  </div>
</header>
<% if (['queue','settings'].includes(active)) { %>
  <nav class="subnav" aria-label="<%= t('nav.system') %>">
    <a class="subnav-link <%= active === 'queue' ? 'active' : '' %>" href="/queue"><%= t('queue') %></a>
    <a class="subnav-link <%= active === 'settings' ? 'active' : '' %>" href="/settings"><%= t('settings') %></a>
  </nav>
<% } %>
<% if (typeof notice !== 'undefined' && notice) { %><div class="flash flash-<%= notice.type || 'success' %>" role="status"><span><%= notice.message %></span><button class="icon-button" type="button" data-dismiss-flash aria-label="<%= t('close') %>">×</button></div><% } %>

<div class="notice">
  <strong>CSV preview</strong>
  <p>Valid: <%= preview.valid.length %> · Invalid: <%= preview.invalid.length %> · Duplicates: <%= preview.duplicates.length %></p>
  <% if (preview.invalid.length) { %><details><summary>Invalid rows</summary><ul><% preview.invalid.forEach((row) => { %><li>Row <%= row.row %>: <%= row.error %></li><% }) %></ul></details><% } %>
  <form method="post" action="/imports/csv/commit"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><button class="button primary" <%= preview.valid.length ? '' : 'disabled' %>>Import and process</button></form>
</div>

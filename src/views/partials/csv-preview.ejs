<% const copy = locale === 'ru' ? { title: 'Проверка CSV', valid: 'Можно импортировать', invalid: 'С ошибками', duplicates: 'Повторы', invalidRows: 'Строки с ошибками', row: 'Строка', import: 'Импортировать и запустить обработку' } : { title: 'CSV check', valid: 'Ready to import', invalid: 'With errors', duplicates: 'Duplicates', invalidRows: 'Rows with errors', row: 'Row', import: 'Import and start processing' }; %>
<div class="notice csv-preview"><strong><%= copy.title %></strong><p><%= copy.valid %>: <%= preview.valid.length %> · <%= copy.invalid %>: <%= preview.invalid.length %> · <%= copy.duplicates %>: <%= preview.duplicates.length %></p><% if (preview.invalid.length) { %><details><summary><%= copy.invalidRows %></summary><ul><% preview.invalid.forEach((row) => { %><li><%= copy.row %> <%= row.row %>: <%= row.error %></li><% }) %></ul></details><% } %><form method="post" action="/imports/csv/commit"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><input type="hidden" name="previewId" value="<%= previewId %>"><input type="hidden" name="previewVersion" value="<%= previewVersion %>"><button class="button primary" <%= preview.valid.length ? '' : 'disabled' %>><%= copy.import %></button></form></div>

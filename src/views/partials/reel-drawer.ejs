<% const copy = locale === 'ru' ? { content: 'Материал', instagram: 'Открыть Instagram', metrics: 'Показатели', caption: 'Описание', transcript: 'Расшифровка', source: 'Источник не указан' } : { content: 'Content', instagram: 'Open Instagram', metrics: 'Metrics', caption: 'Caption', transcript: 'Transcript', source: 'No source' }; %>
<div class="drawer-header"><div><span class="eyebrow"><%= copy.content %></span><h2>@<%= reel.username %></h2></div><button class="icon-button" type="button" data-close-drawer aria-label="<%= t('close') %>">×</button></div><div class="drawer-body"><% if (reel.thumbnail_url) { %><img class="thumbnail drawer-thumbnail" src="/media/reels/<%= reel.id %>/thumbnail" alt=""><% } %><a class="button secondary full" href="<%= reel.reel_url %>" target="_blank" rel="noopener"><%= copy.instagram %> ↗</a><section><h3><%= copy.metrics %></h3><div class="metrics metrics-large"><span><strong><%= reel.play_count == null ? '—' : Number(reel.play_count).toLocaleString(locale) %></strong><small><%= t('metric.plays') %></small></span><span><strong><%= reel.like_count == null ? '—' : Number(reel.like_count).toLocaleString(locale) %></strong><small><%= t('metric.likes') %></small></span><span><strong><%= reel.comment_count == null ? '—' : Number(reel.comment_count).toLocaleString(locale) %></strong><small><%= t('metric.comments') %></small></span></div></section><section><h3><%= copy.caption %></h3><p><%= reel.caption || '—' %></p></section><section><h3><%= copy.transcript %></h3><div class="chips"><span class="chip"><%= t(`status.${reel.transcript_status}`) %></span><span class="chip"><%= reel.transcript_source || copy.source %></span><span class="chip quality-<%= reel.transcript_quality || 'unclassified' %>"><%= t(`quality.${reel.transcript_quality || 'unclassified'}`) %></span></div><p class="transcript-text"><%= reel.transcript_text || '—' %></p><small class="muted"><%= reel.transcript_quality_reason || reel.transcript_error || '' %></small></section></div>

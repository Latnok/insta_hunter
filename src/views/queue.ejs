<%- include('partials/head', { title }) %><%- include('partials/nav', { active }) %>
<main class="page"><div class="page-heading"><h1><%= title %></h1></div><form class="filters" method="get"><select name="status"><option value="">all statuses</option><% ['pending','running','retry_wait','succeeded','failed','cancelled'].forEach((s) => { %><option value="<%= s %>" <%= query.status === s ? 'selected' : '' %>><%= s %></option><% }) %></select><input name="jobType" value="<%= query.jobType || '' %>" placeholder="job type"><button class="button secondary"><%= t('search') %></button></form>
<section class="table-card"><table><thead><tr><th>Job</th><th>Account</th><th>Status</th><th>Attempts</th><th>Created</th><th></th></tr></thead><tbody><% jobs.forEach((job) => { %><tr><td><strong><%= job.job_type %></strong><small class="block"><%= job.error_summary || '' %></small></td><td><%= job.username ? `@${job.username}` : '—' %></td><td><span class="chip"><%= job.status %></span></td><td><%= job.attempts %>/<%= job.max_attempts %></td><td><time data-utc="<%= job.created_at.toISOString() %>"></time></td><td><% if (job.status === 'failed') { %><form method="post" action="/jobs/<%= job.id %>/retry"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><button class="button secondary">Retry</button></form><% } %><% if (['pending','retry_wait'].includes(job.status)) { %><form method="post" action="/jobs/<%= job.id %>/cancel"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><button class="button danger">Cancel</button></form><% } %></td></tr><% }) %></tbody></table></section>
</main><%- include('partials/foot') %>

<% const copy = locale === 'ru' ? { subtitle: 'Фоновые процессы поиска и анализа', errors: 'Требуют внимания', active: 'В работе', completed: 'Завершено за 24 часа', allStatuses: 'Все состояния', allTypes: 'Все типы задач', task: 'Задача', account: 'Аккаунт', status: 'Состояние', attempts: 'Попытки', created: 'Создана', actions: 'Действия', retry: 'Повторить', cancel: 'Отменить', emptyTitle: 'Задач не найдено', emptyText: 'Попробуйте изменить фильтры.', technical: 'Техническая ошибка' } : { subtitle: 'Background search and analysis processes', errors: 'Needs attention', active: 'In progress', completed: 'Completed in 24 hours', allStatuses: 'All statuses', allTypes: 'All task types', task: 'Task', account: 'Account', status: 'Status', attempts: 'Attempts', created: 'Created', actions: 'Actions', retry: 'Retry', cancel: 'Cancel', emptyTitle: 'No tasks found', emptyText: 'Try changing the filters.', technical: 'Technical error' }; %>
<%- include('partials/head', { title }) %><%- include('partials/nav', { active }) %>
<main class="page"><div class="page-heading"><div><span class="eyebrow"><%= t('system') %> · <%= title %></span><h1><%= title %></h1><p class="muted"><%= copy.subtitle %></p></div></div>
<section class="summary-grid"><a class="summary-card <%= jobSummary.failed ? 'summary-danger' : '' %>" href="/queue?status=failed"><span><%= copy.errors %></span><strong><%= jobSummary.failed %></strong></a><a class="summary-card" href="/queue?status=running"><span><%= copy.active %></span><strong><%= jobSummary.active %></strong></a><div class="summary-card"><span><%= copy.completed %></span><strong><%= jobSummary.completed_today %></strong></div></section>
<form class="filters filter-bar" method="get"><label><span class="sr-only"><%= copy.status %></span><select name="status"><option value=""><%= copy.allStatuses %></option><% ['failed','running','pending','retry_wait','succeeded','cancelled'].forEach((s) => { %><option value="<%= s %>" <%= query.status === s ? 'selected' : '' %>><%= t(`status.${s}`) %></option><% }) %></select></label><label><span class="sr-only"><%= copy.task %></span><select name="jobType"><option value=""><%= copy.allTypes %></option><% jobTypes.forEach((type) => { %><option value="<%= type %>" <%= query.jobType === type ? 'selected' : '' %>><%= t(`job.${type}`) %></option><% }) %></select></label><button class="button secondary"><%= t('search') %></button></form>
<% if (!jobs.length) { %><section class="empty-state"><div class="empty-icon">✓</div><h2><%= copy.emptyTitle %></h2><p><%= copy.emptyText %></p></section><% } else { %><section class="table-card"><table><thead><tr><th><%= copy.task %></th><th><%= copy.account %></th><th><%= copy.status %></th><th><%= copy.attempts %></th><th><%= copy.created %></th><th><span class="sr-only"><%= copy.actions %></span></th></tr></thead><tbody><% jobs.forEach((job) => { %><tr class="job-row job-<%= job.status %>"><td><strong><%= t(`job.${job.job_type}`) %></strong><% if (job.error_summary) { %><details class="error-details"><summary><%= copy.technical %></summary><small><%= job.error_summary %></small></details><% } %></td><td><%= job.username ? `@${job.username}` : '—' %></td><td><span class="chip status-<%= job.status %>"><%= t(`status.${job.status}`) %></span></td><td><%= job.attempts %>/<%= job.max_attempts %></td><td><time data-utc="<%= job.created_at.toISOString() %>"></time></td><td><div class="row-actions"><% if (job.status === 'failed') { %><form method="post" action="/jobs/<%= job.id %>/retry" data-confirm="<%= copy.retry %>?"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><button class="button secondary"><%= copy.retry %></button></form><% } %><% if (['pending','running','retry_wait'].includes(job.status)) { %><form method="post" action="/jobs/<%= job.id %>/cancel" data-confirm="<%= copy.cancel %>?"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><button class="button danger"><%= copy.cancel %></button></form><% } %></div></td></tr><% }) %></tbody></table></section><% } %>
</main><%- include('partials/foot') %>

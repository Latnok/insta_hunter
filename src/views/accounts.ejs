<%- include('partials/head', { title }) %><%- include('partials/nav', { active }) %>
<main class="page">
  <div class="page-heading"><div><h1><%= title %></h1><p class="muted"><%= mode === 'candidates' ? 'Discovery and review pipeline' : 'Approved blogger registry' %></p></div></div>
  <% if (mode === 'candidates') { %>
  <section class="toolbar-panel">
    <form method="post" action="/accounts" class="toolbar-form"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><input name="account" placeholder="@username or Instagram URL" required><button class="button primary"><%= t('add') %></button></form>
    <form method="post" action="/discovery-runs" class="toolbar-form"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><input name="query" placeholder="fashion moscow" required><input class="small-input" type="number" name="limit" min="1" max="<%= config.DISCOVERY_MAX_LIMIT %>" value="<%= config.DISCOVERY_DEFAULT_LIMIT %>"><button class="button secondary"><%= t('search') %></button></form>
    <form hx-post="/imports/csv/preview" hx-target="#csv-preview" hx-encoding="multipart/form-data" class="toolbar-form"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><input type="file" name="file" accept=".csv,text/csv" required><button class="button secondary">CSV preview</button></form>
    <div id="csv-preview"></div>
  </section>
  <div hx-get="/ui/discovery-runs" hx-trigger="load" hx-swap="innerHTML"></div>
  <% } %>
  <form class="filters" method="get"><input name="search" value="<%= query.search || '' %>" placeholder="@username"><select name="status"><% if (mode === 'candidates') { %><option value="candidate">candidate</option><option value="rejected" <%= query.status === 'rejected' ? 'selected' : '' %>>rejected</option><% } else { %><option value="approved">approved</option><option value="archived" <%= query.status === 'archived' ? 'selected' : '' %>>archived</option><% } %></select><button class="button secondary"><%= t('search') %></button></form>
  <% if (!accounts.length) { %><div class="empty"><%= t('noData') %></div><% } %>
  <section class="card-grid"><% accounts.forEach((account) => { %><%- include('partials/account-card', { account, mode, config }) %><% }) %></section>
  <% if (accounts.length === 24) { %><a class="button secondary load-more" href="?<%= new URLSearchParams({ ...query, offset: Number(query.offset || 0) + 24 }).toString() %>"><%= t('loadMore') %></a><% } %>
</main><%- include('partials/foot') %>

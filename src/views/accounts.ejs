<%- include('partials/head', { title }) %><%- include('partials/nav', { active }) %>
<main class="page">
  <div class="page-heading"><div><h1><%= title %></h1><p class="muted"><%= mode === 'candidates' ? 'Discovery and review pipeline' : 'Approved blogger registry' %></p></div></div>
  <% if (mode === 'candidates') { %>
  <section class="toolbar-panel candidate-tools">
    <div class="discovery-search stack">
      <div><h2>Поиск новых блогеров</h2><p class="muted">Опишите, каких авторов нужно найти, или попросите ИИ подготовить запрос по одобренным и отклонённым примерам.</p></div>
      <form method="post" action="/discovery-runs" class="toolbar-form discovery-search-form">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <label class="field-grow"><span>Поисковый запрос</span><input id="discovery-query" name="query" value="<%= aiSearchQueries[0] || '' %>" list="discovery-query-options" placeholder="Например: блогеры с обзорами женской одежды" maxlength="200" autocomplete="off" required><datalist id="discovery-query-options"><% aiSearchQueries.forEach((item) => { %><option value="<%= item %>"><% }) %></datalist></label>
        <label><span>Сколько кандидатов</span><input class="small-input" type="number" name="limit" min="1" max="<%= config.DISCOVERY_MAX_LIMIT %>" value="<%= config.DISCOVERY_DEFAULT_LIMIT %>"></label>
        <button class="button primary search-submit">Найти кандидатов</button>
      </form>
      <% if (aiSearchQueries.length) { %>
        <div id="ai-query-suggestion" class="ai-query-suggestion"><div><strong>Запрос подготовлен ИИ</strong><small class="muted block">В поле уже подставлен первый вариант. Нажмите стрелку в поле, чтобы выбрать один из <%= aiSearchQueries.length %> вариантов.</small></div><form hx-post="/discovery-query-suggestions" hx-target="#ai-query-suggestion" hx-swap="outerHTML"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><button class="button secondary">Сформировать заново</button></form></div>
      <% } else { %><div id="ai-query-suggestion" class="ai-query-suggestion">
        <form hx-post="/discovery-query-suggestions" hx-target="#ai-query-suggestion" hx-swap="outerHTML">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <button class="button secondary">Предложить запрос через ИИ</button>
        </form>
        <small class="muted">ИИ проанализирует доступные профили и полезные расшифровки, создаст черновик критериев и подставит поисковую фразу.</small>
      </div><% } %>
    </div>
    <div class="candidate-imports stack">
      <h2>Добавить напрямую</h2>
      <form method="post" action="/accounts" class="toolbar-form"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><input name="account" placeholder="@username или ссылка Instagram" required><button class="button secondary"><%= t('add') %></button></form>
      <form hx-post="/imports/csv/preview" hx-target="#csv-preview" hx-encoding="multipart/form-data" class="toolbar-form"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><input type="file" name="file" accept=".csv,text/csv" required><button class="button secondary">Проверить CSV</button></form>
    </div>
    <div id="csv-preview"></div>
  </section>
  <% } %>
  <form class="filters" method="get"><input name="search" value="<%= query.search || '' %>" placeholder="@username"><select name="status"><% if (mode === 'candidates') { %><option value="candidate">candidate</option><option value="rejected" <%= query.status === 'rejected' ? 'selected' : '' %>>rejected</option><% } else { %><option value="approved">approved</option><option value="archived" <%= query.status === 'archived' ? 'selected' : '' %>>archived</option><% } %></select><button class="button secondary"><%= t('search') %></button></form>
  <% if (!accounts.length) { %><div class="empty"><%= t('noData') %></div><% } %>
  <section class="card-grid"><% accounts.forEach((account) => { %><%- include('partials/account-card', { account, mode, config }) %><% }) %></section>
  <% if (accounts.length === 24) { %><a class="button secondary load-more" href="?<%= new URLSearchParams({ ...query, offset: Number(query.offset || 0) + 24 }).toString() %>"><%= t('loadMore') %></a><% } %>
</main><%- include('partials/foot') %>

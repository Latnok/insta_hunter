<% const copy = locale === 'ru' ? {
  candidatesSubtitle: 'Найдите авторов, дождитесь анализа и примите решение', bloggersSubtitle: 'Одобренные авторы и предложения о сотрудничестве',
  findTitle: 'Найти новых блогеров', findHelp: 'Опишите, каких авторов вы ищете. Можно использовать обычную фразу — сервис сам запустит поиск и анализ.',
  query: 'Кого ищем', queryPlaceholder: 'Например: блогеры с обзорами женской одежды', amount: 'Количество', find: 'Начать поиск',
  aiReady: 'ИИ предложил варианты запроса', aiReadyHelp: 'Первый вариант уже выбран. Другие варианты доступны в списке поля.', regenerate: 'Предложить заново', aiSuggest: 'Помочь составить запрос', aiHelp: 'ИИ учтёт решения по уже проверенным кандидатам.',
  other: 'Другие способы добавления', otherHelp: 'Добавьте один Instagram-аккаунт или импортируйте список из CSV.', direct: 'Аккаунт или ссылка Instagram', csv: 'Выбрать CSV', checkCsv: 'Проверить файл',
  searchPlaceholder: 'Имя или @username', allCandidates: 'На рассмотрении', rejected: 'Отклонённые', approved: 'Активные', archived: 'Архив', found: 'Показано', profiles: 'профилей', emptyTitle: 'Здесь пока пусто', emptyCandidates: 'Начните поиск или добавьте аккаунт вручную.', emptyBloggers: 'Одобренные кандидаты появятся здесь.'
} : {
  candidatesSubtitle: 'Find creators, wait for analysis, and make a decision', bloggersSubtitle: 'Approved creators and collaboration proposals',
  findTitle: 'Find new creators', findHelp: 'Describe the creators you need in plain language. The service will start search and analysis.',
  query: 'Who are you looking for?', queryPlaceholder: 'For example: creators reviewing women’s clothing', amount: 'Quantity', find: 'Start search',
  aiReady: 'AI suggested search options', aiReadyHelp: 'The first option is selected. More options are available in the field list.', regenerate: 'Suggest again', aiSuggest: 'Help me write a query', aiHelp: 'AI will use decisions from previously reviewed candidates.',
  other: 'Other ways to add', otherHelp: 'Add one Instagram account or import a CSV list.', direct: 'Instagram account or link', csv: 'Choose CSV', checkCsv: 'Check file',
  searchPlaceholder: 'Name or @username', allCandidates: 'For review', rejected: 'Rejected', approved: 'Active', archived: 'Archive', found: 'Showing', profiles: 'profiles', emptyTitle: 'Nothing here yet', emptyCandidates: 'Start a search or add an account manually.', emptyBloggers: 'Approved candidates will appear here.'
}; %>
<%- include('partials/head', { title }) %><%- include('partials/nav', { active }) %>
<main class="page">
  <div class="page-heading"><div><span class="eyebrow"><%= mode === 'candidates' ? '01' : '02' %> · <%= title %></span><h1><%= title %></h1><p class="muted"><%= mode === 'candidates' ? copy.candidatesSubtitle : copy.bloggersSubtitle %></p></div></div>
  <% if (mode === 'candidates') { %>
    <section class="search-workspace panel">
      <div class="section-heading"><div><h2><%= copy.findTitle %></h2><p class="muted"><%= copy.findHelp %></p></div></div>
      <form method="post" action="/discovery-runs" class="discovery-form">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <label class="field-grow"><span><%= copy.query %></span><input id="discovery-query" name="query" value="<%= aiSearchQueries[0] || '' %>" list="discovery-query-options" placeholder="<%= copy.queryPlaceholder %>" maxlength="200" autocomplete="off" required><datalist id="discovery-query-options"><% aiSearchQueries.forEach((item) => { %><option value="<%= item %>"><% }) %></datalist></label>
        <label class="field-compact"><span><%= copy.amount %></span><input type="number" name="limit" min="1" max="<%= config.DISCOVERY_MAX_LIMIT %>" value="<%= config.DISCOVERY_DEFAULT_LIMIT %>"></label>
        <button class="button primary button-large"><%= copy.find %></button>
      </form>
      <div id="ai-query-suggestion" class="ai-helper">
        <% if (aiSearchQueries.length) { %><div><strong><%= copy.aiReady %></strong><small class="muted block"><%= copy.aiReadyHelp %></small></div><form hx-post="/discovery-query-suggestions" hx-target="#ai-query-suggestion" hx-swap="outerHTML"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><button class="button tertiary"><%= copy.regenerate %></button></form>
        <% } else { %><form hx-post="/discovery-query-suggestions" hx-target="#ai-query-suggestion" hx-swap="outerHTML"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><button class="button tertiary"><%= copy.aiSuggest %></button></form><small class="muted"><%= copy.aiHelp %></small><% } %>
      </div>
      <details class="secondary-tools"><summary><span><%= copy.other %></span><small><%= copy.otherHelp %></small></summary><div class="secondary-tools-grid">
        <form method="post" action="/accounts" class="stack"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><label><span><%= copy.direct %></span><input name="account" placeholder="@username" required></label><button class="button secondary"><%= t('add') %></button></form>
        <form hx-post="/imports/csv/preview" hx-target="#csv-preview" hx-encoding="multipart/form-data" class="stack"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><label><span><%= copy.csv %></span><input type="file" name="file" accept=".csv,text/csv" required></label><button class="button secondary"><%= copy.checkCsv %></button></form>
      </div><div id="csv-preview"></div></details>
    </section>
  <% } %>
  <section class="results-header">
    <form class="filters" method="get"><label class="search-field"><span class="sr-only"><%= t('search') %></span><input name="search" value="<%= query.search || '' %>" placeholder="<%= copy.searchPlaceholder %>"></label><label><span class="sr-only">Status</span><select name="status"><% if (mode === 'candidates') { %><option value="candidate"><%= copy.allCandidates %></option><option value="rejected" <%= query.status === 'rejected' ? 'selected' : '' %>><%= copy.rejected %></option><% } else { %><option value="approved"><%= copy.approved %></option><option value="archived" <%= query.status === 'archived' ? 'selected' : '' %>><%= copy.archived %></option><% } %></select></label><button class="button secondary"><%= t('search') %></button></form>
    <p class="result-count"><%= copy.found %>: <strong><%= accounts.length %></strong> <%= copy.profiles %></p>
  </section>
  <% if (!accounts.length) { %><section class="empty-state"><div class="empty-icon">◎</div><h2><%= copy.emptyTitle %></h2><p><%= mode === 'candidates' ? copy.emptyCandidates : copy.emptyBloggers %></p></section><% } else { %>
    <section class="card-grid"><% accounts.forEach((account) => { %><%- include('partials/account-card', { account, mode, config }) %><% }) %></section>
  <% } %>
  <% if (accounts.length === 24) { %><a class="button secondary load-more" href="?<%= new URLSearchParams({ ...query, offset: Number(query.offset || 0) + 24 }).toString() %>"><%= t('loadMore') %></a><% } %>
</main><%- include('partials/foot') %>
